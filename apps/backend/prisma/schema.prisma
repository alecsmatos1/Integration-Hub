generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connections IntegrationConnection[]
  endpoints   WebhookEndpoint[]
  workflows   Workflow[]
}

model IntegrationProvider {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  connections IntegrationConnection[]
  endpoints   WebhookEndpoint[]
}

model IntegrationConnection {
  id         String   @id @default(uuid())
  userId     String
  providerId String
  name       String
  config     Json     @default("{}")
  secret     String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id])
  provider  IntegrationProvider @relation(fields: [providerId], references: [id])
  endpoints WebhookEndpoint[]
}

model WebhookEndpoint {
  id           String   @id @default(uuid())
  userId       String
  providerId   String
  connectionId String
  name         String
  pathToken    String   @unique @default(uuid())
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User                  @relation(fields: [userId], references: [id])
  provider   IntegrationProvider   @relation(fields: [providerId], references: [id])
  connection IntegrationConnection @relation(fields: [connectionId], references: [id])
  events     WebhookEvent[]
}

model WebhookEvent {
  id                String   @id @default(uuid())
  endpointId        String
  provider          String
  eventType         String
  externalEventId   String?
  headers           Json
  rawPayload        Json
  normalizedPayload Json
  signatureValid    Boolean
  receivedAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  endpoint   WebhookEndpoint     @relation(fields: [endpointId], references: [id])
  executions WorkflowExecution[]
}

model Workflow {
  id              String   @id @default(uuid())
  userId          String
  name            String
  triggerProvider String
  triggerEvent    String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id])
  steps      WorkflowStep[]
  executions WorkflowExecution[]
}

model WorkflowStep {
  id         String   @id @default(uuid())
  workflowId String
  order      Int
  type       String
  provider   String?
  action     String?
  config     Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workflow Workflow       @relation(fields: [workflowId], references: [id])
  logs     ExecutionLog[]
}

model WorkflowExecution {
  id             String    @id @default(uuid())
  workflowId     String
  webhookEventId String?
  status         String    @default("pending")
  startedAt      DateTime?
  finishedAt     DateTime?
  durationMs     Int?
  retryCount     Int       @default(0)
  errorMessage   String?
  createdAt      DateTime  @default(now())

  workflow     Workflow      @relation(fields: [workflowId], references: [id])
  webhookEvent WebhookEvent? @relation(fields: [webhookEventId], references: [id])
  logs         ExecutionLog[]
}

model ExecutionLog {
  id          String   @id @default(uuid())
  executionId String
  stepId      String?
  level       String
  message     String
  metadata    Json?
  createdAt   DateTime @default(now())

  execution WorkflowExecution @relation(fields: [executionId], references: [id])
  step      WorkflowStep?     @relation(fields: [stepId], references: [id])
}
